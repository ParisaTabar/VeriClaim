# VeriClaim Academic Demo Environment
# Copy this file to .env and replace placeholders where needed.

POSTGRES_DB=vericlaim_db
POSTGRES_USER=vericlaim_user
POSTGRES_PASSWORD=vericlaim_pass

N8N_HOST=localhost
N8N_WEBHOOK_URL_PUBLIC=http://localhost:5678/
N8N_ENCRYPTION_KEY=replace_with_a_random_32_character_string

# OpenAlex requests should include a real contact email, but do not commit it publicly.
OPENALEX_MAILTO=your.email@example.com

# Keep actual API keys inside n8n credentials, not in GitHub.
VERICLAIM_MODEL_NAME=llama-3.1-8b-instant

GENERIC_TIMEZONE=Europe/Berlin
TZ=Europe/Berlin
